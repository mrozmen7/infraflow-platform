{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "infraflow-web": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.scss"
            ],
            "security": {
              "autoCsp": true
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "330kB",
                  "maximumError": "380kB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                },
                {
                  "type": "bundle",
                  "name": "incident-create-page",
                  "maximumWarning": "85kB",
                  "maximumError": "100kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "mock": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "fileReplacements": [
                {
                  "replace": "src/app/app.config.ts",
                  "with": "src/app/app.config.mock.ts"
                }
              ]
            },
            "pages-demo": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "330kB",
                  "maximumError": "380kB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                },
                {
                  "type": "bundle",
                  "name": "incident-create-page",
                  "maximumWarning": "85kB",
                  "maximumError": "100kB"
                }
              ],
              "outputHashing": "all",
              "baseHref": "/infraflow-platform/",
              "fileReplacements": [
                {
                  "replace": "src/app/app.config.ts",
                  "with": "src/app/app.config.pages-demo.ts"
                }
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "infraflow-web:build:production"
            },
            "development": {
              "buildTarget": "infraflow-web:build:development",
              "proxyConfig": "proxy.conf.json"
            },
            "mock": {
              "buildTarget": "infraflow-web:build:mock"
            },
            "pages-demo": {
              "buildTarget": "infraflow-web:build:pages-demo"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
